{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ghost-x.local/schemas/tracker_status.schema.json",
  "title": "GHOST-X Tracker Status Payload",
  "type": "object",
  "required": [
    "schema_version",
    "contract_version",
    "tracker",
    "sequence",
    "frame_id",
    "visible",
    "status_text",
    "live_status",
    "measurement_age_s",
    "units",
    "provenance",
    "timestamps",
    "validity"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "contract_version": {"const": "ghost-x-data-contract-v1"},
    "tracker": {"enum": ["formal_imm", "ghost_mh"]},
    "sequence": {"type": "integer", "minimum": 0},
    "frame_id": {"type": "string", "minLength": 1},
    "visible": {"type": "boolean"},
    "status_text": {"type": "string"},
    "live_status": {"type": "string"},
    "measurement_age_s": {"type": ["number", "null"], "minimum": 0},
    "units": {
      "type": "object",
      "required": ["position", "velocity", "time"],
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "required": ["calibration_id", "configuration_id", "configuration_label"],
      "properties": {
        "calibration_id": {"type": "string", "minLength": 1},
        "configuration_id": {"type": "string", "minLength": 1},
        "configuration_label": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "timestamps": {
      "type": "object",
      "required": ["source_time_s", "receipt_time_s", "processing_time_s", "publication_time_s"],
      "properties": {
        "source_time_s": {"type": ["number", "null"]},
        "receipt_time_s": {"type": ["number", "null"]},
        "processing_time_s": {"type": ["number", "null"]},
        "publication_time_s": {"type": ["number", "null"]}
      },
      "additionalProperties": false
    },
    "validity": {
      "type": "object",
      "required": ["is_valid", "state"],
      "properties": {
        "is_valid": {"type": "boolean"},
        "state": {"enum": ["WAITING_FOR_TARGET", "VALID_TRACKING", "VALID_PREDICTION_ONLY", "DEGRADED", "INVALID", "MISSION_COMPLETE"]},
        "reason": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
