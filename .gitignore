build/
*.o
*.a
*.so

# ── Compiler/linker cache ──────────────────────────────────────────────────────
.cache/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
*.swp
*.swo
